{
  "name": "kanban-pro",
  "version": "1.0.5",
  "description": "Local-first Kanban / PM boards for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:parser:property": "vitest run --dir src/core/parser",
    "test:edit-loss": "vitest run --dir src/core/__tests__/editLoss",
    "test:lifecycle": "vitest run --dir src/__tests__/lifecycle",
    "test:license": "vitest run --dir src/pro/license/__tests__",
    "bench": "node scripts/bench.mjs",
    "validate": "node scripts/validate.mjs",
    "validate:fixtures": "node scripts/validate.mjs src/core/parser/__tests__/fixtures/all-inline-meta.md src/core/parser/__tests__/fixtures/archive.md src/core/parser/__tests__/fixtures/basic.md src/core/parser/__tests__/fixtures/complete-lane.md src/core/parser/__tests__/fixtures/settings-block-current.md src/core/parser/__tests__/fixtures/settings-block.md src/core/parser/__tests__/fixtures/subtasks.md src/core/parser/__tests__/fixtures/recurrence-rrule.md",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": ["obsidian", "kanban", "plugin", "pm"],
  "license": "MIT",
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "@octokit/core": "^6.1.2",
    "@tanstack/react-virtual": "^3.10.8",
    "chrono-node": "^2.7.7",
    "dayjs": "^1.11.13",
    "ics": "^3.7.6",
    "immer": "^10.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "rrule": "^2.8.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.5.1",
    "zustand": "^5.0.0-rc.2"
  },
  "overrides": {
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.10.0",
    "fast-check": "^3.22.0",
    "jsdom": "^25.0.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.7.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
